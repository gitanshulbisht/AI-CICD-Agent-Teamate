# .env.example

# n8n basic authentication
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here

# GitHub credentials
GITHUB_TOKEN=ghp_your_github_personal_access_token
GH_REPO=your_github_username/your_repository_name

# ArgoCD credentials
ARGOCD_SERVER=host.docker.internal:8080
ARGOCD_AUTH_TOKEN=your_argocd_admin_token

# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenRouter LLM credentials (Note: base url should be https://openrouter.ai/api without trailing /v1/chat/completions)
OPENROUTER_API_KEY=your_openrouter_api_key
