        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "run_id": "={{ $fromAI('run_id') }}",
            "app_name": "={{ $fromAI('app_name') }}"
          }
        }
      },
      "id": "tool-argocd_app_status",
      "name": "Tool: argocd_app_status",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 1.2,
      "position": [
        1000,
        450
      ]
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "",
          "mode": "id"
        },
        "name": "argocd_sync_app",
        "description": "Syncs app. Needs app_name",
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "run_id": "={{ $fromAI('run_id') }}",
            "app_name": "={{ $fromAI('app_name') }}"
          }
        }
      },
      "id": "tool-argocd_sync_app",
      "name": "Tool: argocd_sync_app",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 1.2,
      "position": [
        1150,
        450
      ]
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "",
          "mode": "id"
        },
        "name": "argocd_app_history",
        "description": "Gets app history. Needs app_name",
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
