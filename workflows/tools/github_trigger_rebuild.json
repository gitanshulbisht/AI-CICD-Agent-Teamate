{
  "name": "github_trigger_rebuild",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "jsCode": "const { execSync } = require('child_process');\nconst data = $input.item.json;\nconst val = (data.query && data.query.run_id) ? data.query.run_id : data.run_id;\nif (!val) { return [{ json: { stdout: '', stderr: 'No run_id provided. Got: ' + JSON.stringify(data) } }]; }\ntry {\n  const cmd = 'gh run rerun ' + val;\n  const stdout = execSync(cmd, { encoding: 'utf8', timeout: 30000 });\n  return [{ json: { stdout: stdout || 'Done.', stderr: '' } }];\n} catch(e) {\n  return [{ json: { stdout: e.stdout || '', stderr: e.stderr || e.message } }];\n}"
      },
      "id": "execute",
      "name": "Github Trigger Rebuild",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "result",
              "value": "={{ $json.stdout || $json.stderr }}"
            }
          ]
        },
        "options": {}
      },
      "id": "set",
      "name": "Set Output",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [440, 0]
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [
          {
            "node": "Github Trigger Rebuild",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Github Trigger Rebuild": {
      "main": [
        [
          {
            "node": "Set Output",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {}
}
